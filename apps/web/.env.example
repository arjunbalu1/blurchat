# Copy to apps/web/.env and fill in. Loaded by `nx serve web` via envFile.
# Railway sets these in the dashboard; this file is local dev only.

# Dev server port. Frontend runs on 5173 locally (matches auth TRUSTED_ORIGINS / api CORS).
# (NODE_ENV is managed by Next per command — don't set it here.)
PORT=5173

# Public backend URLs the browser calls. NEXT_PUBLIC_* are inlined at BUILD time,
# so on Railway they must be set as BUILD variables (not just runtime).
# Local: http://localhost:3000 (api) · http://localhost:3001 (auth)
# Prod:  https://api.chatarooni.com · https://auth.chatarooni.com
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_URL=http://localhost:3001

LOG_LEVEL=debug

# OpenTelemetry — leave OTEL_EXPORTER_OTLP_ENDPOINT empty to run with tracing OFF.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-credentials>
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=chatarooni-web
# AlwaysOn (default) | AlwaysOff | traceidratio (+ OTEL_TRACES_SAMPLER_ARG=0.1)
OTEL_TRACES_SAMPLER=AlwaysOn


# MUST match apps/auth's BETTER_AUTH_SECRET exactly. Lets apps/web verify the
# session cookie locally (getCookieCache) instead of hopping to apps/auth on
# every render. If unset, session reads silently fall back to the network path.
BETTER_AUTH_SECRET=
